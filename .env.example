# ==========================================================
# .env.example
# Plantilla de variables usadas por docker-compose.yml
# Copia este archivo como ".env" y ajusta los valores
# ==========================================================

# ----------------------------------------------------------
# Base de datos PostgreSQL
# ----------------------------------------------------------
POSTGRES_DB=dastxh
POSTGRES_USER=dastxh
POSTGRES_PASSWORD=dastxh
POSTGRES_PORT=5432

# ----------------------------------------------------------
# Orquestador / backend web
# ----------------------------------------------------------
DEFAULT_TIMEOUT_SECONDS=30
WEB_PORT=8000

# ----------------------------------------------------------
# pgAdmin
# ----------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@dastxhdemo.com
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050