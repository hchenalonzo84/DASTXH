# ==========================================================
# .env.example
# - Plantilla de variables usadas por docker-compose.yml
# - Copia este archivo como ".env" (mismo contenido)
# ==========================================================

# Base de datos (nombre lógico)
POSTGRES_DB=dastxh

# Usuario de Postgres
POSTGRES_USER=dastxh

# Password de Postgres
POSTGRES_PASSWORD=dastxh

# Timeout por defecto del orquestador (segundos)
DEFAULT_TIMEOUT_SECONDS=30