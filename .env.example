# ==========================================================
# DASTXH - Base de datos principal
# ==========================================================
POSTGRES_DB=dastxh
POSTGRES_USER=dastxh_user
POSTGRES_PASSWORD=dastxh_pass
POSTGRES_PORT=5432

# ==========================================================
# DASTXH - Backend / GUI
# ==========================================================
DEFAULT_TIMEOUT_SECONDS=30
WEB_PORT=8000

# ==========================================================
# pgAdmin
# ==========================================================
PGADMIN_DEFAULT_EMAIL=admin@dastxhdemo.com
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050

# ==========================================================
# Laboratorio combinado
# Base de datos propia del laboratorio
# ==========================================================
COMBO_LAB_POSTGRES_DB=combo_lab
COMBO_LAB_POSTGRES_USER=combo_user
COMBO_LAB_POSTGRES_PASSWORD=combo_pass
COMBO_LAB_POSTGRES_PORT=5543

# Puerto web del laboratorio
COMBO_LAB_PORT=5003

# ==========================================================
# DASTXH - Interpretación XSS con IA local
# Docker Model Runner / endpoint OpenAI-compatible
# ==========================================================
DASTXH_AI_ENABLED=true
DASTXH_AI_BASE_URL=http://model-runner.docker.internal:12434/engines/v1
DASTXH_AI_MODEL=ai/llama3.2
DASTXH_AI_API_KEY=not-needed

# Tiempo máximo por llamada/lote al modelo.
# No es timeout global del escaneo completo.
DASTXH_AI_TIMEOUT_SECONDS=420

# Máximo de tokens que puede generar el modelo por lote.
# Ayuda a evitar respuestas demasiado largas o lentas.
DASTXH_AI_MAX_TOKENS=1200

# Temperatura baja para que responda más estable y con JSON más consistente.
DASTXH_AI_TEMPERATURE=0.1

# Máximo de grupos XSS que se enviarán a IA.
# Normalmente 20 es suficiente porque ya se agrupa antes.
DASTXH_AI_MAX_GROUPS=20

# Cantidad de grupos por llamada al modelo.
# 5 es buen punto inicial para evitar HTTP 400 por prompts grandes.
DASTXH_AI_BATCH_SIZE=5

# Cantidad máxima de payloads representativos por grupo.
DASTXH_AI_MAX_PAYLOADS_PER_GROUP=2

# Longitud máxima de cada payload enviado a IA.
DASTXH_AI_MAX_PAYLOAD_CHARS=180

# Cantidad máxima de evidencias representativas por grupo.
DASTXH_AI_MAX_EVIDENCE_PER_GROUP=1

# Longitud máxima de cada evidencia enviada a IA.
DASTXH_AI_MAX_EVIDENCE_CHARS=260

# ==========================================================
# DASTXH - Traducción hsecscan con IA local
# Docker Model Runner / endpoint OpenAI-compatible
# ==========================================================
# Activa la traducción asistida para los campos de hsecscan:
# - Descripción
# - Recomendación
# - CWE
#
# Importante:
# Esta función NO interpreta nuevos riesgos.
# Solo traduce al español latino los textos técnicos ya generados por hsecscan.
DASTXH_HSECSCAN_AI_TRANSLATION_ENABLED=true

# Se reutiliza el mismo endpoint local compatible con OpenAI.
DASTXH_HSECSCAN_AI_TRANSLATION_BASE_URL=http://model-runner.docker.internal:12434/engines/v1

# Se reutiliza el mismo modelo local.
DASTXH_HSECSCAN_AI_TRANSLATION_MODEL=ai/llama3.2

# Docker Model Runner normalmente no requiere una API key real.
DASTXH_HSECSCAN_AI_TRANSLATION_API_KEY=not-needed

# Timeout por lote de traducción.
# Puede ser menor que XSS porque hsecscan traduce texto más corto.
DASTXH_HSECSCAN_AI_TRANSLATION_TIMEOUT_SECONDS=300

# Temperatura baja para obtener traducciones más estables.
DASTXH_HSECSCAN_AI_TRANSLATION_TEMPERATURE=0.1

# Máximo de tokens de salida para traducciones hsecscan.
# Esta variable es específica porque el servicio nuevo lee MAX_OUTPUT_TOKENS.  valor de antes 2500
DASTXH_HSECSCAN_AI_TRANSLATION_MAX_OUTPUT_TOKENS=3000

# Cantidad de checks de hsecscan por llamada al modelo.
# 8 es un punto equilibrado para traducción técnica.
DASTXH_HSECSCAN_AI_TRANSLATION_BATCH_SIZE=1

# Límite máximo de checks de hsecscan que se enviarán a traducción.
DASTXH_HSECSCAN_AI_TRANSLATION_MAX_ITEMS=80

# Longitud máxima por campo traducible:
# security_description, recommendations y cwe. valor de antes 900
DASTXH_HSECSCAN_AI_TRANSLATION_MAX_CHARS_PER_FIELD=650